        remote_ip => {127,0,0,1},
        remote_udp_port => 5556
      },

      #{
        id => peer_b,
        remote_peer_id => peer_a,
        psk => <<"0123456789abcdef0123456789abcdef">>,
        mode => tun,
        ifname => <<"tun1">>,
        ip => "10.20.20.2",
        local_udp_port => 5556,
        remote_ip => {127,0,0,1},
        remote_udp_port => 5555
      }
    ]}
  ]}
].
