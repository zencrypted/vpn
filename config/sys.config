  {kernel, [
    {logger_level, info}
  ]},

  {vpn, [
    {peers, [
      #{
        id => peer_a,
        name => <<"Peer A">>,
        remote_peer_id => peer_b,
        psk => <<"0123456789abcdef0123456789abcdef">>,
        mode => tun,
        ifname => <<"tun0">>,
        ip => "10.20.20.1",
